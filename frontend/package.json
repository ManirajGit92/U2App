{
  "name": "u2-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-with-tanglish.ps1",
    "start:frontend": "ng serve",
    "start:python-api": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"cd ../backend/python-service; ./.venv/Scripts/python -m uvicorn app.main:socket_app --host 127.0.0.1 --port 8000\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@9.4.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@supabase/supabase-js": "^2.99.1",
    "buffer": "^6.0.3",
    "diff": "^8.0.3",
    "docx": "^8.5.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "mermaid": "^11.13.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tesseract.js": "^5.1.1",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
